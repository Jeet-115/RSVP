{
  "name": "birthday-rsvp",
  "private": true,
  "version": "1.0.0",
  "description": "Private birthday invitation + RSVP collector (MERN, Vite, Tailwind)",
  "scripts": {
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "dev": "concurrently -k \"npm:dev:*\"",
    "build": "npm --prefix client run build",
    "start:server": "npm --prefix server run start",
    "postinstall": "npm --prefix client ci"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
